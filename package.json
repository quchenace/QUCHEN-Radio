{
  "name": "quchen",
  "productName": "QuchenRadio",
  "version": "1.5.1",
  "description": "可独立运行的本地音乐播放器、跨平台歌单工具与桌面音乐可视化应用。",
  "author": "QuchenRadio contributors",
  "license": "MIT",
  "main": "desktop/main.js",
  "homepage": "https://github.com/quchenace/QUCHEN-Radio",
  "repository": {
    "type": "git",
    "url": "https://github.com/quchenace/QUCHEN-Radio.git"
  },
  "bugs": {
    "url": "https://github.com/quchenace/QUCHEN-Radio/issues"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "quchen": {
    "update": {
      "provider": "github",
      "owner": "quchenace",
      "repo": "QUCHEN-Radio",
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://gh-proxy.com/"
      ]
    }
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.quchen.radio",
    "productName": "QuchenRadio",
    "artifactName": "Quchen-Radio-${version}-Setup.${ext}",
    "asar": false,
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "server.js",
      "lx-source-host.js",
      "lx-search.js",
      "platform-playlist-import.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    }
  }
}
